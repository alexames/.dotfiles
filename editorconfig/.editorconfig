# Global EditorConfig defaults. Most plugins walk up from the edited file and
# stop at the first file with `root = true`, so a project-level .editorconfig
# overrides this one.

root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

[*.{md,markdown}]
trim_trailing_whitespace = false   # trailing 2-space = hard line break

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{js,jsx,ts,tsx,html,css,scss,vue}]
indent_size = 2

[*.{lua,sh,bash,zsh,fish}]
indent_size = 2

[Makefile]
indent_style = tab

[*.go]
indent_style = tab
